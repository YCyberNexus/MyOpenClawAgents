# req_dispatcher 部署期配置（deployment-time pin）。
# 在每台部署本 agent 的 runner 上编辑一次；agent 运行时不改写本文件。
#
# 重要：group / project / 具体目标仓 —— 不在此处。
# 这是全公司共用链路，目标 project 随需求文本传入，由 git_issuer 自己从文本解析。

# 下游目标 agent 名（req_dispatcher 跨 agent 派发给它建 issue + 打执行器入口标签）。
GIT_ISSUER_AGENT=git_issuer

# 运行时 state 根目录：pending.json / ledger.jsonl / 锁 / 序号 / 日志 都在 ${STATE_ROOT}/_dispatcher/ 下。
# 必须是 server 上 agent 可写的持久目录。
STATE_ROOT=/data/req_dispatcher

# stuck/timeout 兜底阈值（分钟）：pending 超过该时长仍没等到 executor 回调 → 合成失败并 drain。
# 取值应略大于 git_issuer 单次建 issue 的预期最大耗时 + 余量。
STUCK_AFTER_MINUTES=30

# 可选：失败通知 channel（launch_failed / git_issuer 失败 / stuck 驱逐时通知运维）。留空则不通知。
# 形态 = 企业微信群机器人 webhook URL（http/https）。消费方：scripts/ops_notify.sh
# （best-effort：发送失败不阻断失败路径，仅形态写错才报错）。要换其它通知形态就改该脚本。
OPS_NOTIFY_CHANNEL=

# 可选：若将来需要 req_dispatcher 向 git_issuer 显式指定执行器入口标签（默认空＝由 git_issuer 自决打哪个标签）。
DEFAULT_ENTRY_LABEL=

# 默认执行器 agent：所有形态合法的 GitLab project（group/project）默认都路由到这里。
# ROUTING_FILE 只作为少数 project 需要专属 executor 时的覆盖表。
DEFAULT_EXECUTOR_AGENT=req_executor

# 下游 agent 单次 turn 调用超时（秒）：run_agent_turn.sh 传给 `openclaw agent --timeout`。
DOWNSTREAM_AGENT_TIMEOUT_SECONDS=600

# 可选 project 覆盖路由表：git_issuer 返回 project 后，先按本表查专属 executor；
# 未命中则回落到 DEFAULT_EXECUTOR_AGENT。行格式 `PROJECT=AGENT`，详见 config/README.md。
# 默认相对 SKILL_DIR（调用约定 `cd "<SKILL_DIR>" && source scripts/source_dispatcher_env.sh`），
# 也可改成 server 上的绝对路径。文件缺失/格式错 → route_project.sh exit 2（部署期配置写错）。
ROUTING_FILE=../../config/routing.env

# 用户结果推送通道：req_dispatcher 主动给企微发起人（origin）推实质结果（受理 ack 之外）。
# 机制已对齐：104 反向调用 114 OpenClaw 网关，把结果信封投给 114 上的接收 agent；
# 接收 agent 负责按 origin 完成企微最后一跳。目标 agent 优先取 origin.reply_agent，
# 该字段为空时才使用 DEFAULT_REPLY_AGENT 兜底。缺少网关 pin 或最终目标 agent＝scripts/notify_user.sh
# no-op（仅记 ledger 留痕、不静默丢）。
REPLY_GATEWAY_URL=
REPLY_GATEWAY_TOKEN=
# 默认接收结果的 114 agent 名；调用方 origin.reply_agent 为空时使用。
DEFAULT_REPLY_AGENT=
REPLY_NOTIFY_TIMEOUT_SECONDS=30

# 结果回调目标：req_dispatcher 调用 req_executor 的 RUN_SINGLE_ISSUE 时，把
# 本值作为 dispatcher_callback_target 传下去（I1 入参）；执行器 Phase 6 终态据此把结果回调投回
# req_dispatcher（I2 信封）。支持 agent:<agent>:<session> 或裸 agent 名；蓝区默认固定 main session。
# 留空＝调用时该字段为空，执行器侧 notify_dispatcher.sh no-op。
DISPATCHER_CALLBACK_TARGET=agent:req_dispatcher:main

# 跨 agent 调用契约已固定为 scripts/run_agent_turn.sh 包装 `openclaw agent`：
#   openclaw agent --agent <target> --session-key <session> --message <payload> --timeout <seconds>
# 该 CLI 使用 runner 已配置的 OpenClaw Gateway，不在本文件重复 pin 网关地址/token。
