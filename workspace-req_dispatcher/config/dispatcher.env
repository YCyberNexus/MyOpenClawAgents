# req_dispatcher 部署期配置（deployment-time pin）。
# 在每台部署本 agent 的 runner 上编辑一次；agent 运行时不改写本文件。
#
# 重要：group / project / 具体目标仓 —— 不在此处。
# 这是全公司共用链路，目标 project 随需求文本传入，由 git_issuer 自己从文本解析。

# 下游目标 agent 名（req_dispatcher 跨 agent 派发给它建 issue + 打执行器入口标签）。
GIT_ISSUER_AGENT=git_issuer

# 运行时 state 根目录：pending.json / ledger.jsonl / 锁 / 序号 / 日志 都在 ${STATE_ROOT}/_dispatcher/ 下。
# 必须是 server 上 agent 可写的持久目录。
STATE_ROOT=/data/req_dispatcher

# stuck/timeout 兜底阈值（分钟）：pending 超过该时长仍没等到 git_issuer 回调 → 合成失败并 drain。
# 取值应略大于 git_issuer 单次建 issue 的预期最大耗时 + 余量。
STUCK_AFTER_MINUTES=30

# 可选：失败通知 channel（launch_failed / git_issuer 失败 / stuck 驱逐时通知运维）。留空则不通知。
# 形态 = 企业微信群机器人 webhook URL（http/https）。消费方：scripts/ops_notify.sh
# （best-effort：发送失败不阻断失败路径，仅形态写错才报错）。要换其它通知形态就改该脚本。
OPS_NOTIFY_CHANNEL=

# 可选：若将来需要 req_dispatcher 向 git_issuer 显式指定执行器入口标签（默认空＝由 git_issuer 自决打哪个标签）。
DEFAULT_ENTRY_LABEL=

# 多 project 路由表文件路径：git_issuer 回调透传回 project 后，按本表选目标 req_executor agent。
# 行格式 `PROJECT=AGENT`，详见该文件头注与 config/README.md。消费方：scripts/route_project.sh。
# 默认相对 SKILL_DIR（调用约定 `cd "<SKILL_DIR>" && source ../../config/dispatcher.env`），
# 也可改成 server 上的绝对路径。文件缺失/格式错 → route_project.sh exit 2（部署期配置写错）。
ROUTING_FILE=../../config/routing.env

# 【待对齐占位】用户出站推送通道：B 方案首次需要 req_dispatcher 主动给企微发起人（origin）推
# 实质结果（受理 ack 之外）。确切机制待对齐（企微 webhook 回投 / 经 114 回投，设计稿 §9.2）。
# 留空＝scripts/notify_user.sh no-op（仅记 ledger 留痕、不静默丢；通道形态写错才报错）。
# 对齐后在此填该通道的连接参数（URL/token 等），并据对齐结果实现 notify_user.sh 的发送原语。
USER_NOTIFY_CHANNEL=

# 【待对齐占位】结果回调目标：req_dispatcher spawn req_executor 的 RUN_SINGLE_ISSUE 时，把
# 本值作为 dispatcher_callback_target 传下去（I1 入参）；执行器 Phase 6 终态据此把结果回调投回
# req_dispatcher（I2 信封）。确切形态 = req_dispatcher 的 agent/session 标识，与跨 agent 回调
# 原语一同待对齐（设计稿 §9.1）。留空＝spawn 时该字段为空，执行器侧 notify_dispatcher.sh no-op。
DISPATCHER_CALLBACK_TARGET=

# 跨 agent 调用原语的连接参数：待与 OpenClaw 维护者/同事对齐后补
# （形态类 sessions_spawn、可指定目标 agent、异步回调；具体工具名与参数见
#  skills/requirement_dispatch/references/trigger_command.md 的占位块）。
# 例如若该原语需要网关地址 / token，则在此补充对应变量。
