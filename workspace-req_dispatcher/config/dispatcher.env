# req_dispatcher 部署期配置（deployment-time pin）。
# 在每台部署本 agent 的 runner 上编辑一次；agent 运行时不改写本文件。
#
# 重要：group / project / 具体目标仓 —— 不在此处。
# 这是全公司共用链路，目标 project 随需求文本传入，由 git_issuer 自己从文本解析。

# 下游目标 agent 名（req_dispatcher 跨 agent 派发给它建 issue + 打 acpx 入口标签）。
GIT_ISSUER_AGENT=git_issuer

# 运行时 state 根目录：pending.json / ledger.jsonl / 锁 / 序号 / 日志 都在 ${STATE_ROOT}/_dispatcher/ 下。
# 必须是 server 上 agent 可写的持久目录。
STATE_ROOT=/data/req_dispatcher

# stuck/timeout 兜底阈值（分钟）：pending 超过该时长仍没等到 git_issuer 回调 → 合成失败并 drain。
# 取值应略大于 git_issuer 单次建 issue 的预期最大耗时 + 余量。
STUCK_AFTER_MINUTES=30

# 可选：失败通知 channel（launch_failed / git_issuer 失败 / stuck 驱逐时通知运维）。留空则不通知。
# 形态 = 企业微信群机器人 webhook URL（http/https）。消费方：scripts/ops_notify.sh
# （best-effort：发送失败不阻断失败路径，仅形态写错才报错）。要换其它通知形态就改该脚本。
OPS_NOTIFY_CHANNEL=

# 可选：若将来需要 req_dispatcher 向 git_issuer 显式指定 acpx 入口标签（默认空＝由 git_issuer 自决打哪个标签）。
DEFAULT_ENTRY_LABEL=

# 跨 agent 调用原语的连接参数：待与 OpenClaw 维护者/同事对齐后补
# （形态类 sessions_spawn、可指定目标 agent、异步回调；具体工具名与参数见
#  skills/requirement_dispatch/references/trigger_command.md 的占位块）。
# 例如若该原语需要网关地址 / token，则在此补充对应变量。
