# GitLab Deployment Pin
#
# These values are committed to the repo and synced to every runner. They
# replace the per-tick host parsing the agent used to do from
# ${GITLAB_ADDRESS}, which was fragile under long-running scheduled execution.
#
# Edit ONLY when you genuinely change which GitLab server this workspace
# talks to. Trigger inputs do not override this file.
#
# This file is `source`d by scripts/glab_auth.sh, so keep it pure
# `KEY=value` lines — no shell logic.

# Hostname (and port if non-default), as glab expects in --hostname.
GITLAB_HOST=gitlab-b.pxsemic.tech:30000

# API protocol — must be exactly "http" or "https".
GITLAB_API_PROTOCOL=http
