# UI Test Account Pool
#
# Used by gitlab_issue_campaign_dispatcher to allocate a distinct test account
# per concurrent subagent. The system under test logs out an account when the
# same credentials log in twice, so concurrent subagents MUST use different
# accounts. With max_concurrent_subagents=N, this pool MUST contain at least
# N entries — otherwise the dispatcher aborts the tick (No-Fallback Policy:
# never share an account between two in-flight subagents).
#
# Format: one account per line, "username:password". Lines starting with #
# and blank lines are ignored. Trailing whitespace is trimmed.
#
# Edited at deployment time, like gitlab.env. Trigger inputs do not override
# this file. Read by scripts/load_ui_accounts.sh.

F100001:123456
F100002:123456
F100003:123456
F100004:123456
