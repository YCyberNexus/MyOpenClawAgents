<mxfile host="Electron" agent="claude">
  <diagram name="主状态机-issue(人)-v2" id="issue-main-v2">
    <mxGraphModel dx="3577" dy="1137" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="m_title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="Issue 主状态机 v2 —— 只画「人需要看到 / 人需要处理」的状态（自动内部步骤见第2页）" vertex="1">
          <mxGeometry height="30" width="1400" x="40" y="20" as="geometry" />
        </mxCell>

        <mxCell id="m_start" parent="1" style="ellipse;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="22" width="22" x="92" y="274" as="geometry" />
        </mxCell>

        <mxCell id="m_QUEUED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;QUEUED · 已登记待处理&lt;/b&gt;&#xa;(label ∈ {todo, new, retry, continue})&#xa;&#xa;entry/ 人工打入口标签 = 状态机起点&#xa;含义/ issue 已登记，等待被自动认领&#xa;人/ 无需介入&#xa;exit/ 被调度器选中 → 进入 doing" vertex="1">
          <mxGeometry height="190" width="300" x="170" y="190" as="geometry" />
        </mxCell>

        <mxCell id="m_AUTO" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;AUTO_RUNNING · 自动处理中&lt;/b&gt; (label = doing)&#xa;&#xa;含义/ issue 已被自动认领，agent 正在处理&#xa;人/ 无需介入，等待结果&#xa;exit/ 产出 outcome(done/blocked/timeout/failed) 写回标签 → 迁移&#xa;&#xa;&lt;i&gt;⟪「怎么处理」属于另一台状态机（调度器/执行），&#xa;见第2页；本页不展开它的内部步骤⟫&lt;/i&gt;" vertex="1">
          <mxGeometry height="210" width="340" x="600" y="190" as="geometry" />
        </mxCell>

        <mxCell id="m_REVIEW" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=11;" value="&lt;b&gt;AWAITING_REVIEW · 待人工评审&lt;/b&gt;&#xa;(labels = done + pr)&#xa;&#xa;entry/ agent 完成并开了 MR → 自动得到 done + pr&#xa;do/ 人工 review 这个 MR&#xa;exit/ 合并 MR → CLOSED&#xa;exit/ 或人工加 continue → 退回 QUEUED 续跑&#xa;&#xa;&lt;i&gt;⟪需要人处理：必须有人 review/合并⟫&lt;/i&gt;" vertex="1">
          <mxGeometry height="210" width="330" x="1070" y="190" as="geometry" />
        </mxCell>

        <mxCell id="m_CLOSED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1e1e1;strokeColor=#666666;verticalAlign=top;fontSize=11;" value="&lt;b&gt;CLOSED · 终态&lt;/b&gt;&#xa;(state=closed)&#xa;&#xa;entry/ MR 合并 → Closes #iid 自动关闭&#xa;entry/ 或人工直接关闭&#xa;do/ reconcile 永久硬跳过，不再调度" vertex="1">
          <mxGeometry height="170" width="280" x="1540" y="210" as="geometry" />
        </mxCell>

        <mxCell id="m_end" parent="1" style="ellipse;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="22" width="22" x="1669" y="470" as="geometry" />
        </mxCell>
        <mxCell id="m_end_inner" parent="1" style="ellipse;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="12" width="12" x="1674" y="475" as="geometry" />
        </mxCell>

        <mxCell id="m_BLOCKED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;align=center;fontSize=12;fontStyle=1;spacingTop=6;" value="BLOCKED · 阻塞（label = blocked）&#10;同一个标签，两类归因 —— 人工据此决定如何处理（见下两格，第7条）" vertex="1">
          <mxGeometry height="330" width="640" x="250" y="640" as="geometry" />
        </mxCell>
        <mxCell id="m_BLOCKED_cc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontSize=10;" value="&lt;b&gt;① CC 侧（Claude Code 工作问题）&lt;/b&gt;&#xa;&#xa;来源: acpx 非超时失败 / NO_CHANGES /&#xa;       push 被拒 / acpx 后续步骤失败&#xa;现场: 可提交的 partial work 已 force-push&#xa;       到 WORK_BRANCH；summary 仅本地&#xa;&#xa;&lt;b&gt;人工处理:&lt;/b&gt;&#xa;• 读 partial+summary → 加 continue 带补充&#xa;  说明（原分支续跑）&#xa;• 或加 retry 干净重做" vertex="1">
          <mxGeometry height="250" width="290" x="270" y="700" as="geometry" />
        </mxCell>
        <mxCell id="m_BLOCKED_disp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontSize=10;" value="&lt;b&gt;② 调度器侧（编排/基础设施问题）&lt;/b&gt;&#xa;&#xa;来源: prep 失败(clone/prepare/prompt/label) /&#xa;       spawn 启动 3 次失败 / scope eviction /&#xa;       子流程未产出 outcome 即报错&#xa;现场: 无 CC 产出；block_reason 记录原因&#xa;&#xa;&lt;b&gt;人工处理:&lt;/b&gt;&#xa;• 多为环境/runner 问题，修复后加 retry&#xa;• scope eviction 不消耗 retry_count" vertex="1">
          <mxGeometry height="250" width="290" x="580" y="700" as="geometry" />
        </mxCell>

        <mxCell id="m_TIMEOUT" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontSize=11;" value="&lt;b&gt;TIMEOUT · 超时停泊&lt;/b&gt; (label = timeout)&#xa;&#xa;entry/ agent 运行超时被中止&#xa;现场/ 分支上有 partial 提交，无 MR/pr&#xa;do/ 不自动重试，不消耗 retry_count&#xa;&#xa;&lt;b&gt;人工处理:&lt;/b&gt;&#xa;• 去掉 timeout / 加 retry → fresh 重做&#xa;• 加 continue → 在已推分支上续跑" vertex="1">
          <mxGeometry height="250" width="300" x="960" y="690" as="geometry" />
        </mxCell>

        <mxCell id="m_FAILED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontSize=11;" value="&lt;b&gt;FAILED · 失败终态&lt;/b&gt; (label = failed)&#xa;&#xa;entry/ outcome=failed&#xa;entry/ 或 retry_count &gt; blocked_retry_limit 被提升&#xa;do/ 永不自动重排&#xa;&#xa;&lt;b&gt;人工处理:&lt;/b&gt;&#xa;• 加 retry/continue 重新武装（仅人工可恢复）&#xa;• 或直接关闭" vertex="1">
          <mxGeometry height="250" width="300" x="1320" y="690" as="geometry" />
        </mxCell>

        <mxCell id="m_decision" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=10;" value="&lt;b&gt;人工行为 ⇄ 自动状态 的融合：重跑该 continue 还是 retry？（第1条）&lt;/b&gt;&#xa;&#xa;&lt;b&gt;判定规则（dispatcher _attempt_mode_for_entry）&lt;/b&gt;&#xa;• 仅当 continue 是&lt;u&gt;唯一&lt;/u&gt;工作标签 → continue 模式&#xa;• 否则（retry/todo/new，或 continue 与其它工作标签并存）→ fresh 模式&#xa;&#xa;&lt;b&gt;continue（续跑 / resume）&lt;/b&gt;&#xa;• 基线 = origin/WORK_BRANCH（上轮 WIP）&#xa;• 恢复上轮 ifp-result/issue-iid 产物&#xa;• prompt 注入上轮 summary + 评审意见&#xa;&#xa;&lt;b&gt;retry（重做 / fresh）&lt;/b&gt;&#xa;• 基线 = origin/DEV_BRANCH（干净）&#xa;• 归档上轮产物，不带入；全新 prompt&#xa;&#xa;&lt;b&gt;经验法则&lt;/b&gt;&#xa;• 上轮方向对、只差细节 → continue&#xa;• 上轮跑偏 / 改了规格或共享配置 → retry" vertex="1">
          <mxGeometry height="340" width="460" x="1700" y="640" as="geometry" />
        </mxCell>

        <mxCell id="m_legend" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;" value="&lt;b&gt;图例&lt;/b&gt;&#xa;━━ 自动转移（B→A：执行结果写回标签）&#xa;┅┅(紫) 人工动作（A→B：打标签 / 合并 / 关闭，驱动调度）&#xa;&#xa;&lt;b&gt;本页范围（第8、9条）&lt;/b&gt;&#xa;只画「人需要看到 / 人需要处理」的状态；不需人介入的内部步骤（prep / spawn / stage / commit / wiki / mr…）下沉到第2页。&#xa;&lt;b&gt;不混画（第6条）：&lt;/b&gt;本页所有结点都是 issue 状态（GitLab 标签可观察）；dispatcher 状态全在第2页，二者只通过实时标签互相驱动。&#xa;BLOCKED 下两格是同一 blocked 标签的「归因」（第7条），属 issue 状态的标注，不是 dispatcher 状态结点。&#xa;&#xa;&lt;b&gt;起点 = 标签（第2条）&lt;/b&gt;&#xa;状态机从人工打入口标签 todo / new 开始，不再画浏览器里建 issue 的 DRAFTING / SUBMITTED 过程。&#xa;&#xa;&lt;b&gt;任意非终态均可被人工 close → CLOSED&lt;/b&gt;（为减少连线，图中只画了 FAILED→CLOSED 一条示例）。&#xa;&#xa;&lt;b&gt;source of truth&lt;/b&gt;&#xa;GitLab 实时标签是状态唯一真相；磁盘 state 只是缓存。每个 tick 先 reconcile 并写证据文件。" vertex="1">
          <mxGeometry height="300" width="900" x="170" y="1040" as="geometry" />
        </mxCell>

        <mxCell id="m_e1" edge="1" parent="1" source="m_start" target="m_QUEUED" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;labelBackgroundColor=#ffffff;" value="人工加 label[todo|new] = 起点">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="m_e2" edge="1" parent="1" source="m_QUEUED" target="m_AUTO" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;labelBackgroundColor=#ffffff;" value="被调度器选中(B驱动A) / set doing（清除其它工作标签，含 done+pr，第4条）">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="m_e3" edge="1" parent="1" source="m_QUEUED" target="m_QUEUED" style="endArrow=classic;html=1;rounded=0;fontSize=10;curved=1;exitX=0.1;exitY=0;entryX=0.3;entryY=0;labelBackgroundColor=#ffffff;" value="本轮未被选中 / 仍排队（issue 状态不变）">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="160" />
              <mxPoint x="260" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m_e4" edge="1" parent="1" source="m_AUTO" target="m_REVIEW" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;labelBackgroundColor=#ffffff;" value="outcome=done / 加 done+pr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="m_e5" edge="1" parent="1" source="m_AUTO" target="m_BLOCKED_cc" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=0.12;exitY=1;entryX=0.5;entryY=0;labelBackgroundColor=#ffffff;" value="outcome=blocked（CC 侧）">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="640" y="560" />
              <mxPoint x="415" y="560" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m_e6" edge="1" parent="1" source="m_AUTO" target="m_BLOCKED_disp" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=0.4;exitY=1;entryX=0.5;entryY=0;labelBackgroundColor=#ffffff;" value="outcome=blocked（调度器侧·无 CC 产出）">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="736" y="610" />
              <mxPoint x="725" y="610" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m_e7" edge="1" parent="1" source="m_AUTO" target="m_TIMEOUT" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=0.72;exitY=1;entryX=0.5;entryY=0;labelBackgroundColor=#ffffff;" value="outcome=timeout">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="845" y="640" />
              <mxPoint x="1110" y="640" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m_e8" edge="1" parent="1" source="m_AUTO" target="m_FAILED" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=0.95;exitY=1;entryX=0.5;entryY=0;labelBackgroundColor=#ffffff;" value="outcome=failed 或 retry&gt;limit 提升">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="923" y="660" />
              <mxPoint x="1470" y="660" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m_e9" edge="1" parent="1" source="m_REVIEW" target="m_CLOSED" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;labelBackgroundColor=#ffffff;" value="人工合并 MR / GitLab 自动关闭">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="m_e10" edge="1" parent="1" source="m_REVIEW" target="m_QUEUED" style="endArrow=classic;html=1;rounded=0;fontSize=10;dashed=1;strokeColor=#9673a6;exitX=0.5;exitY=0;entryX=0.85;entryY=0;labelBackgroundColor=#ffffff;" value="人工加 continue / 退回续跑(resume)">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1235" y="140" />
              <mxPoint x="425" y="140" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m_e11" edge="1" parent="1" source="m_BLOCKED" target="m_QUEUED" style="endArrow=classic;html=1;rounded=0;fontSize=10;dashed=1;strokeColor=#9673a6;exitX=0;exitY=0.3;entryX=0.2;entryY=1;labelBackgroundColor=#ffffff;" value="人工加 retry(fresh) 或 continue(resume)">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="130" y="739" />
              <mxPoint x="130" y="420" />
              <mxPoint x="230" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m_e12" edge="1" parent="1" source="m_BLOCKED" target="m_FAILED" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=0.92;exitY=1;entryX=0.5;entryY=1;labelBackgroundColor=#ffffff;" value="retry_count &gt; blocked_retry_limit / 自动提升">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="839" y="1010" />
              <mxPoint x="1470" y="1010" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="m_e13" edge="1" parent="1" source="m_TIMEOUT" target="m_QUEUED" style="endArrow=classic;html=1;rounded=0;fontSize=10;dashed=1;strokeColor=#9673a6;exitX=0.2;exitY=0;entryX=0.4;entryY=1;labelBackgroundColor=#ffffff;" value="去 timeout/加 retry(fresh) 或 加 continue(resume)">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1020" y="440" />
