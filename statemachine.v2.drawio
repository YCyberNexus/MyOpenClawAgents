        <mxCell id="p2_labeldone" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;verticalAlign=top;fontSize=11;" value="&lt;b&gt;LABEL DONE&lt;/b&gt;&#xa;&#xa;doing → done（临时，建 MR 后被 pr 替换）&#xa;labels_removed += doing&#xa;labels_added += done" vertex="1">
