  <diagram name="调度器+执行状态机(自动)-v2" id="dispatcher-exec-v2">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="3600" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p2_title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="调度器 / 执行 状态机 v2（CampaignWorkflow + IssueAttemptWorkflow）—— 自动半区，不需人介入（第6、8条）" vertex="1">
          <mxGeometry height="30" width="1600" x="20" y="6" as="geometry" />
        </mxCell>
        <mxCell id="p2_couple" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=11;" value="&lt;b&gt;与主状态机的耦合（第6条）&lt;/b&gt;　本页所有状态都是 doing 内部的自动步骤。主状态机的 AUTO_RUNNING ⇄ 本页：&#xa;　• 入口由主状态机驱动：tick 读到入口标签 → 启动子流程（START CHILD）；　• 出口驱动主状态机：本页产出的 AttemptOutcome 写回 GitLab 标签 → 推动主状态机迁移。&#xa;　• outcome → 标签映射：done→pr（pr 替换 done）｜CC 侧失败→blocked-cc｜调度器侧失败→blocked-dispatcher｜acpx 超时→timeout｜重试超限→failed。唯一接口 = GitLab 实时标签。" vertex="1">
          <mxGeometry height="80" width="3540" x="20" y="40" as="geometry" />
        </mxCell>
        <mxCell id="p2_band1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eaf2fd;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#4a6fa5;" value="CampaignWorkflow / dispatcher 准备阶段（调度器侧）" vertex="1">
          <mxGeometry height="300" width="1760" x="20" y="150" as="geometry" />
        </mxCell>
        <mxCell id="p2_band2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ecf6ea;strokeColor=#82b366;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#5a8a4a;" value="IssueAttemptWorkflow child / 技术执行（CC 侧）" vertex="1">
          <mxGeometry height="820" width="3540" x="20" y="490" as="geometry" />
        </mxCell>
        <mxCell id="p2_band3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#666666;" value="CampaignWorkflow outcome 记账（调度器侧）" vertex="1">
