        <mxCell id="p2_claude" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;verticalAlign=top;fontSize=11;" value="&lt;b&gt;CLAUDE CODE RUN&lt;/b&gt;&#xa;&#xa;run_claude_code_attempt&#xa;acpx claude exec -f prompt.txt&#xa;one-shot, no retry&#xa;timeout = acpx_timeout_seconds + 120" vertex="1">
