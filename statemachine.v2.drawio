          <mxGeometry height="240" width="330" x="2300" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="p2_final" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;verticalAlign=top;align=left;spacingLeft=10;fontSize=11;" value="&lt;b&gt;FINAL BUCKETS&lt;/b&gt;&#xa;&#xa;&lt;font color=&quot;#5a8a4a&quot;&gt;completed_iids&lt;/font&gt;: status=done, retry counters cleared&#xa;&lt;font color=&quot;#d79b00&quot;&gt;timeout_iids&lt;/font&gt;: status=timeout (CC 侧), parked&#xa;&lt;font color=&quot;#b85450&quot;&gt;blocked_iids&lt;/font&gt;: status=blocked-cc / blocked-dispatcher, retry_count++ + cooldown&#xa;&lt;font color=&quot;#666666&quot;&gt;failed_cc_iids&lt;/font&gt;: status=failed-cc（blocked-cc retry 超限提升）&#xa;&lt;font color=&quot;#666666&quot;&gt;failed_dispatcher_iids&lt;/font&gt;: status=failed-dispatcher（blocked-dispatcher retry 超限提升）" vertex="1">
          <mxGeometry height="290" width="640" x="2720" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="p2_e_await_record" edge="1" parent="1" source="p2_await" style="endArrow=classic;html=1;rounded=0;exitX=0.2;exitY=1;entryX=0.7;entryY=0;fontSize=10;labelBackgroundColor=#f5f5f5;" target="p2_record" value="drain + record">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="3046" y="1390" />
              <mxPoint x="2531" y="1390" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="p2_e_record_final" edge="1" parent="1" source="p2_record" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#f5f5f5;" target="p2_final" value="classify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2_notes" parent="1" style="shape=note;size=16;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;" value="&lt;b&gt;走线规则&lt;/b&gt;　主执行流只展示 happy path：失败 / timeout 从下方进入 AttemptOutcome merge，再返回 AWAIT CHILD。&#xa;&#xa;&lt;b&gt;blocked 归因 → 两个独立 label（第7条，看到即知改哪边）&lt;/b&gt;&#xa;【CC 侧 → blocked-cc】BLOCKED_PUSH / FAIL FLOW —— Claude Code 工作问题，多带 partial work。人去改 issue 提示词 + hulat。&#xa;【调度器侧 → blocked-dispatcher】SYNTHETIC —— prep failure / child error / scope eviction / 等不到回调(stuck)，无 CC 产出。人去改 dispatcher agent。&#xa;【CC 侧 → timeout】acpx 跑超 wall-clock，单独 label；不消耗 retry budget；人去改提示词/hulat 缩小任务，或 continue。&#xa;&#xa;&lt;b&gt;Agent 语义&lt;/b&gt;　CampaignWorkflow 只在 retry budget exhausted 时按侧提升：blocked-cc → failed-cc、blocked-dispatcher → failed-dispatcher（timeout 不消耗 retry、永不提升）。&#xa;本页依据 workspace-acpx_auto_tester/temporal/workflows/campaign.py 与 issue_attempt.py 的已实现流程（label 拆分 + pr 替换 done 均为本次设计提案，落地需改 ensure_labels / set_issue_label / reconcile(has_done_pr→has_pr) / campaign 分类 / executor 的 add_pr；failed 按侧拆需同步 ensure_labels / set_issue_label 互斥组 / campaign buckets / reconcile）。" vertex="1">
          <mxGeometry height="360" width="1180" x="70" y="1420" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="耦合与决策参考-v2" id="coupling-ref-v2">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="2300" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p3_title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="两个状态机如何互相驱动 + label 模型 / 重跑差异 / blocked 归因（评审第3、5、6、7条）" vertex="1">
          <mxGeometry height="30" width="1700" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p3_machineA" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=center;fontSize=13;spacingTop=10;" value="&lt;b&gt;Issue 主状态机（人）&lt;/b&gt;&#xa;&#xa;QUEUED → AUTO_RUNNING → AWAITING_REVIEW&#xa;　↘ blocked-cc / blocked-dispatcher / timeout&#xa;　　/ failed-cc / failed-dispatcher → CLOSED&#xa;&#xa;只含人需要看到 / 处理的状态&#xa;（第1页）" vertex="1">
          <mxGeometry height="230" width="440" x="110" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p3_machineB" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecf6ea;strokeColor=#82b366;verticalAlign=top;align=center;fontSize=13;spacingTop=10;" value="&lt;b&gt;调度器 / 执行状态机（自动）&lt;/b&gt;&#xa;&#xa;BOOTSTRAP→SELECT→PREPARE→START CHILD&#xa;→ CLAUDE RUN→…→ OUTCOME → AWAIT/RECORD&#xa;&#xa;doing 内部自动步骤，不需人介入&#xa;（第2页）" vertex="1">
          <mxGeometry height="200" width="460" x="980" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p3_iface" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" value="唯一接口&#xa;GitLab 实时标签&#xa;(source of truth)" vertex="1">
          <mxGeometry height="90" width="160" x="630" y="175" as="geometry" />
        </mxCell>
        <mxCell id="p3_e_ab" edge="1" parent="1" source="p3_machineA" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.3;entryX=0;entryY=0.3;fontSize=11;labelBackgroundColor=#ffffff;strokeColor=#9673a6;" target="p3_machineB" value="A→B 标签事件 = 调度输入&#xa;todo / new / retry / continue / close&#xa;（tick 读到标签 → 启动子流程）">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="p3_e_ba" edge="1" parent="1" source="p3_machineB" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0.75;entryX=1;entryY=0.75;fontSize=11;labelBackgroundColor=#ffffff;strokeColor=#82b366;" target="p3_machineA" value="B→A 执行结果 = 标签写回&#xa;pr(替换 done) / blocked-cc / blocked-dispatcher / timeout / failed-cc / failed-dispatcher&#xa;（outcome 写回 → 推动主状态机迁移）">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="p3_t1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;" value="&lt;b&gt;① 标签模型：label 要不要独立？（第3条）&lt;/b&gt;&#xa;&#xa;结论（v2 更新）：pr 改为&lt;u&gt;替换&lt;/u&gt; done 后，工作标签收敛成&#xa;&lt;b&gt;单一互斥维度&lt;/b&gt;，不再有独立附加标志。&#xa;&#xa;&lt;b&gt;生命周期状态（互斥，任意时刻恰好一个）&lt;/b&gt;&#xa;　入口: todo / new / retry / continue&#xa;　进行: doing&#xa;　产出(临时): done —— 写完 Wiki、建 MR 前的过渡&#xa;　待评审: pr —— 建 MR 后由 pr 替换 done（done 被移除）&#xa;　异常: blocked-cc / blocked-dispatcher / timeout / failed-cc / failed-dispatcher&#xa;　（blocked 与 failed 均按归因拆成两侧独立 label —— 第7条）&#xa;&#xa;&lt;b&gt;互斥规则（set_issue_label.sh）&lt;/b&gt;&#xa;　加任一工作标签都会移除其它工作标签；&#xa;　{done+pr} 不再并存（pr 替换 done）；&#xa;　仅 {done+blocked-cc 或 done+blocked-dispatcher} 是建 MR 前失败的瞬态。&#xa;　→ 不再分两维：pr 是「待评审」生命周期状态，整套互斥。" vertex="1">
          <mxGeometry height="400" width="650" x="110" y="400" as="geometry" />
        </mxCell>
        <mxCell id="p3_t2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;" value="&lt;b&gt;② retry vs continue 的结果差异（第5条）&lt;/b&gt;&#xa;&#xa;&lt;b&gt;　　　　　　retry / fresh　　│　continue / resume&lt;/b&gt;&#xa;worktree 基线  origin/DEV_BRANCH │ origin/WORK_BRANCH&#xa;上轮产物　　　 归档不带入　　　　│ 恢复 ifp-result/issue-iid&#xa;prompt　　　　 全新　　　　　　　│ 注入上轮 summary+评审意见&#xa;触发标签　　　 retry/todo/new　　│ continue(且为唯一工作标签)&#xa;MR　　　　　　 轮换出新 MR　　　 │ 轮换出新 MR(Supersedes 旧)&#xa;pr　　　　　　 进 doing 即清除　　│ 进 doing 即清除&#xa;适用　　　　　 上轮跑偏/改了规格　│ 上轮方向对、续做&#xa;&#xa;&lt;b&gt;重跑后 pr 是否删？（第4条）&lt;/b&gt;&#xa;　删。进入 doing 的那一步 set_issue_label.sh 会移除&#xa;　{todo,new,retry,continue,done,pr,blocked-cc,blocked-dispatcher,&#xa;　timeout,failed}，只留 doing；若本轮再次完成会轮换新 MR 并重新打 pr（pr 替换 done）。" vertex="1">
          <mxGeometry height="380" width="720" x="820" y="400" as="geometry" />
        </mxCell>
        <mxCell id="p3_t3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;" value="&lt;b&gt;③ blocked / failed 归因 → 按侧拆成独立 label / 状态（第7条 · 核心：看到即知怎么处理）&lt;/b&gt;&#xa;&#xa;&lt;b&gt;blocked-cc（CC 侧：Claude Code 工作问题）&lt;/b&gt;&#xa;　来源: acpx 非超时失败 / NO_CHANGES / push 被拒 / acpx 后步骤失败&#xa;　现场: 有 partial work 在 WORK_BRANCH&#xa;　&lt;b&gt;看到就去：改 issue 提示词 + hulat 配置&lt;/b&gt; → 再 retry 或 continue&#xa;&#xa;&lt;b&gt;blocked-dispatcher（调度器侧：编排 / 基础设施问题）&lt;/b&gt;&#xa;　来源: prep 失败 / spawn 3 次失败 / scope eviction / 子流程错误 / 等不到回调(stuck)&#xa;　现场: 无 CC 产出，看 block_reason&#xa;　&lt;b&gt;看到就去：改 dispatcher agent（环境/runner/编排）&lt;/b&gt; → 修好后 retry&#xa;&#xa;&lt;b&gt;timeout（CC 侧：acpx 跑超 wall-clock）&lt;/b&gt; 单独 label，不消耗 retry_count&#xa;　&lt;b&gt;看到就去：改提示词/hulat 缩小任务&lt;/b&gt; → 去 timeout/retry，或 continue&#xa;&#xa;&lt;b&gt;failed-cc / failed-dispatcher（失败终态 · 同理按侧拆，retry budget 耗尽后提升）&lt;/b&gt;&#xa;　failed-cc ← blocked-cc 超限 → 改提示词/hulat；failed-dispatcher ← blocked-dispatcher 超限 → 改 dispatcher。&#xa;　重新武装：failed-cc 升 model 档，failed-dispatcher 不升（与同侧 blocked 规则一致）。&#xa;&#xa;两类 blocked / 两类 failed 现在各是独立 label，用户在 GitLab 上一眼看出该改哪边，不必再翻 block_reason。" vertex="1">
          <mxGeometry height="420" width="1050" x="110" y="820" as="geometry" />
        </mxCell>
        <mxCell id="p3_t4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;" value="&lt;b&gt;④ 人工行为 ⇄ 自动状态 的融合（第1条）&lt;/b&gt;&#xa;&#xa;第一步 看 label 归因，决定去改哪边：&#xa;• blocked-cc / timeout / failed-cc → 改 issue 提示词 + hulat 配置&#xa;• blocked-dispatcher / failed-dispatcher → 改 dispatcher agent&#xa;&#xa;第二步 决定重跑模式（_attempt_mode_for_entry）：&#xa;• 加 continue（且 continue 是唯一工作标签）→ continue 模式：&#xa;　在 origin/WORK_BRANCH 上续跑，恢复上轮产物 + 注入上轮 summary/评审意见。&#xa;• 加 retry / todo / new（或 continue 与其它工作标签并存）→ fresh 模式：&#xa;　重置到 origin/DEV_BRANCH 干净基线，归档上轮产物。&#xa;&#xa;经验法则:&#xa;• 上轮方向对、只差细节 / 只在 issue 留补充说明 → continue&#xa;• 上轮跑偏，或改了规格 / 共享配置 / 要从头来 → retry&#xa;&#xa;注意: agent 永不自己打 continue；continue 永远是人工评审动作。" vertex="1">
          <mxGeometry height="320" width="980" x="1180" y="820" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="model自动升级状态机-v2" id="model-tier-v2">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="2700" pageHeight="1720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p4_title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="Model 自动升级状态机 v2 —— 按 issue 解决质量自动逐级升档；硬失败 ∪ 软评分触发；model:{tier} 正交持久标签为准（per-issue 单调不降）" vertex="1">
          <mxGeometry height="30" width="2400" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p4_start" parent="1" style="ellipse;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="24" width="24" x="90" y="280" as="geometry" />
        </mxCell>
        <mxCell id="p4_TIER0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;TIER_0 · model:flash&lt;/b&gt;（最低档·默认）&#xa;&#xa;entry/ 新 issue 首次 PREPARE 显式打最低档标签&#xa;含义/ 用最便宜模型先试（trigger model 列表第1档）&#xa;do/ acpx 用 flash 跑本 issue 的 attempt&#xa;exit/ [UPGRADE? 命中] → 升 TIER_1&#xa;internal: [无升级信号] / —（保持 flash，不重入 entry/exit）" vertex="1">
          <mxGeometry height="240" width="430" x="180" y="180" as="geometry" />
        </mxCell>
        <mxCell id="p4_TIER1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;TIER_1 · model:pro&lt;/b&gt;（中档）&#xa;&#xa;entry/ 由 [UPGRADE? 命中] 从 flash 档升入（标签变更见转移效果）&#xa;含义/ 用更强模型（trigger model 列表第2档）&#xa;do/ acpx 用 pro 跑本 issue 后续 attempt&#xa;exit/ [UPGRADE? 再命中] → 升 TIER_2&#xa;internal: [无升级信号] / —（保持 pro）" vertex="1">
          <mxGeometry height="240" width="430" x="720" y="180" as="geometry" />
        </mxCell>
        <mxCell id="p4_TIER2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontSize=11;" value="&lt;b&gt;TIER_2 · model:max&lt;/b&gt;（封顶档·最强）&#xa;&#xa;entry/ 由 [UPGRADE? 命中] 从 pro 档升入（标签变更见转移效果）&#xa;含义/ trigger model 列表最后一档（封顶）&#xa;do/ acpx 用最强模型跑&#xa;exit/ 已封顶（无出边）&#xa;internal: [命中 ∨ 无信号] / —（都保持 max）&#xa;&lt;i&gt;⟪档数 = trigger 可配有序列表；此处 3 档为示例⟫&lt;/i&gt;" vertex="1">
          <mxGeometry height="240" width="470" x="1260" y="180" as="geometry" />
        </mxCell>
        <mxCell id="p4_aggregator" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" value="&lt;b&gt;升级信号聚合器　UPGRADE? = 硬触发 ∪ 软触发&lt;/b&gt;&#xa;&#xa;&lt;b&gt;【硬触发】&lt;/b&gt;上一轮 outcome ∈ { blocked-cc, timeout, failed-cc }&#xa;　✗ blocked-dispatcher / failed-dispatcher 不算（基础设施侧，升 model 无用）&#xa;&#xa;&lt;b&gt;【软触发 · 任一命中即可】&lt;/b&gt;&#xa;　• 人工质量标签 quality:low（人加；升档生效后移除，一次性）&#xa;　• continue 累计次数 ≥ N（阈值，trigger 可配）&#xa;　• 自动评分 &amp;lt; 阈值　……（黑盒 · 未实现 · 占位）&#xa;&#xa;&lt;b&gt;判定：&lt;/b&gt;命中且未封顶 → 升一档　｜　命中但已封顶 → 保持 max　｜　未命中 → 保持当前档" vertex="1">
          <mxGeometry height="380" width="900" x="180" y="560" as="geometry" />
        </mxCell>
        <mxCell id="p4_blackbox" parent="1" style="shape=note;size=16;whiteSpace=wrap;html=1;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;fontColor=#666666;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=11;" value="&lt;b&gt;自动评分子流程&lt;/b&gt;&#xa;（未实现 · 占位）&#xa;&#xa;评估 attempt 结果质量&#xa;→ 低分作软信号&#xa;现作黑盒，后续接入" vertex="1">
          <mxGeometry height="150" width="320" x="1140" y="560" as="geometry" />
        </mxCell>
        <mxCell id="p4_resolve" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2fd;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=11;" value="&lt;b&gt;RESOLVE MODEL TIER&lt;/b&gt;&#xa;（第2页 PREPARE 阶段 · START CHILD 之前执行）&#xa;&#xa;1. 读当前档 = reconcile 后的 model:{tier} 标签&#xa;　（无标签 → 默认 TIER_0）&#xa;2. 评估 UPGRADE?（硬 ∪ 软，基于导致本次排程的上一轮历史）&#xa;3. 命中且未封顶 → 加新 model:{tier}、移除旧档&#xa;　（仅 model 维度内部互斥）&#xa;4. 注入解析出的 model → build_prompt → acpx 调用&#xa;&#xa;&lt;i&gt;→ 第4页状态机的「执行点」：每次 attempt 开始解析一次&lt;/i&gt;" vertex="1">
          <mxGeometry height="300" width="590" x="1140" y="760" as="geometry" />
        </mxCell>
        <mxCell id="p4_labels" parent="1" style="shape=note;size=16;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" value="&lt;b&gt;标签模型：model:{tier} 是正交持久维度&lt;/b&gt;&#xa;&#xa;• 与工作标签（todo/doing/done/pr/blocked-cc/blocked-dispatcher/timeout/failed-cc/failed-dispatcher）正交并存&#xa;• 互斥只在 model 维度内部：任意时刻恰好一个 model:{tier}&#xa;• 单调：只会被换成更高档，永不降（per-issue 跟随终身到 CLOSED）&#xa;• &lt;b&gt;★关键耦合：&lt;/b&gt;进 doing 清空工作标签那一步【不清除】model:{tier}&#xa;• source of truth = GitLab 标签；state.json 缓存 model_tier；reconcile 让缓存向标签看齐&#xa;• 新 issue 无 model:{tier} → 视为 TIER_0；首次 PREPARE 显式打最低档标签" vertex="1">
          <mxGeometry height="340" width="820" x="180" y="1100" as="geometry" />
        </mxCell>
        <mxCell id="p4_couple" parent="1" style="shape=note;size=16;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" value="&lt;b&gt;与其它两台状态机的耦合&lt;/b&gt;&#xa;&#xa;&lt;b&gt;【第1页 · 人】&lt;/b&gt;&#xa;　• model:{tier} 在 GitLab 一眼可见&#xa;　• 人可加 quality:low 软提示促下一轮升档&#xa;　• 无人工直接锁档/重置标签（纯自动单调升）&#xa;&#xa;&lt;b&gt;【第2页 · 调度器】&lt;/b&gt;&#xa;　• RESOLVE MODEL TIER 嵌在 PREPARE 阶段&#xa;　• 升级在「重新武装并进 doing」时发生&#xa;　• 注入的 model 进 build_prompt → acpx&#xa;&#xa;唯一状态载体 = GitLab model:{tier} 标签" vertex="1">
          <mxGeometry height="340" width="690" x="1040" y="1100" as="geometry" />
        </mxCell>
        <mxCell id="p4_legend" parent="1" style="shape=note;size=16;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=11;" value="&lt;b&gt;图例&lt;/b&gt;　━━ 升级转移（UPGRADE? 命中 → 加更高档标签）　保持当前档 = 各档 internal transition（不画自环）　┄┄(灰) 未实现占位&#xa;&lt;b&gt;核心思想：&lt;/b&gt;按 issue 解决质量自动逐级升 model；省钱优先（先 flash），证明不够才升（pro → max）；单调不降、跟随 issue 终身。&#xa;&lt;b&gt;触发：&lt;/b&gt;硬失败(blocked-cc / timeout / failed-cc) ∪ 软评分(quality:low / continue ≥ N / 自动评分 &amp;lt; 阈值[未实现])。　&lt;b&gt;排除：&lt;/b&gt;blocked-dispatcher / failed-dispatcher（基础设施侧）不升 model。&#xa;&lt;b&gt;解析时机：&lt;/b&gt;调度器 PREPARE 阶段（START CHILD 之前）求值并写 model:{tier} 标签；state.json 缓存，GitLab 标签为 source of truth。" vertex="1">
