  <diagram name="调度器+执行状态机(自动)-v2" id="dispatcher-exec-v2">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="3600" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p2_title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="调度器 / 执行 状态机 v2（CampaignWorkflow + IssueAttemptWorkflow）—— 自动半区，不需人介入（第6、8条）" vertex="1">
          <mxGeometry height="30" width="1600" x="20" y="6" as="geometry" />
        </mxCell>
        <mxCell id="p2_couple" parent="1" style="shape=note;size=16;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontSize=11;" value="&lt;b&gt;与主状态机的耦合（第6条）&lt;/b&gt;　本页所有状态都是 doing 内部的自动步骤。主状态机的 AUTO_RUNNING ⇄ 本页：&#xa;　• 入口由主状态机驱动：tick 读到入口标签 → 启动子流程（START CHILD）；　• 出口驱动主状态机：本页产出的 AttemptOutcome 写回 GitLab 标签 → 推动主状态机迁移。&#xa;　• outcome → 标签映射：done→pr（pr 替换 done）｜CC 侧失败→blocked-cc｜调度器侧失败→blocked-dispatcher｜acpx 超时→timeout｜重试超限→failed。唯一接口 = GitLab 实时标签。" vertex="1">
          <mxGeometry height="80" width="3540" x="20" y="40" as="geometry" />
        </mxCell>
        <mxCell id="p2_band1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eaf2fd;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#4a6fa5;" value="CampaignWorkflow / dispatcher 准备阶段（调度器侧）" vertex="1">
          <mxGeometry height="300" width="1760" x="20" y="150" as="geometry" />
        </mxCell>
        <mxCell id="p2_band2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ecf6ea;strokeColor=#82b366;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#5a8a4a;" value="IssueAttemptWorkflow child / 技术执行（CC 侧）" vertex="1">
          <mxGeometry height="820" width="3540" x="20" y="490" as="geometry" />
        </mxCell>
        <mxCell id="p2_band3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#666666;" value="CampaignWorkflow outcome 记账（调度器侧）" vertex="1">
          <mxGeometry height="430" width="3540" x="20" y="1350" as="geometry" />
        </mxCell>
        <mxCell id="p2_bootstrap" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;BOOTSTRAP + RECONCILE&lt;/b&gt;&#xa;&#xa;ensure_workflow_labels&#xa;self_heal_safety_bin&#xa;clone_or_pull_repo&#xa;reconcile_gitlab + classify" vertex="1">
          <mxGeometry height="180" width="300" x="70" y="220" as="geometry" />
        </mxCell>
        <mxCell id="p2_select" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;SELECT BATCH&lt;/b&gt;&#xa;&#xa;continue → reopened → fresh → blocked cooldown&#xa;cap by max_concurrent_subagents&#xa;     + hourly_issue_quota&#xa;respect whitelist + require_labels" vertex="1">
          <mxGeometry height="180" width="330" x="470" y="220" as="geometry" />
        </mxCell>
        <mxCell id="p2_prepare" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;PREPARE IID&lt;/b&gt;&#xa;&#xa;load UI pool + acquire slot&#xa;allocate_attempt_number&#xa;prepare_attempt_worktree&#xa;mark_issue_doing&#xa;resolve_model_tier → inject model（见第4页）&#xa;build_executor_prompt&#xa;(secrets dereferenced worker-side)" vertex="1">
          <mxGeometry height="215" width="340" x="900" y="220" as="geometry" />
        </mxCell>
        <mxCell id="p2_startchild" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;START CHILD&lt;/b&gt;&#xa;&#xa;IssueAttemptWorkflow.run&#xa;id = issue:{project}:{iid}:att-NNN&#xa;WorkflowIDReusePolicy.REJECT_DUPLICATE&#xa;ParentClosePolicy.ABANDON&#xa;add iid to pending" vertex="1">
          <mxGeometry height="180" width="320" x="1300" y="220" as="geometry" />
        </mxCell>
        <mxCell id="p2_modelnote" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#9673a6;" value="★ 第4页 Model 自动升级状态机：PREPARE 的 resolve_model_tier 按 上一轮 outcome(硬: blocked-cc / timeout / failed) ∪ quality:low / continue≥N / 自动评分[未实现](软) 逐级升 model:{tier}（正交持久标签，进 doing 不清除）。" vertex="1">
          <mxGeometry height="28" width="1760" x="70" y="458" as="geometry" />
        </mxCell>
        <mxCell id="p2_e_bs_sel" edge="1" parent="1" source="p2_bootstrap" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#eaf2fd;" target="p2_select" value="reconcile evidence">
          <mxGeometry relative="1" as="geometry" />
