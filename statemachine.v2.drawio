      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="p3_title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="两个状态机如何互相驱动 + label 模型 / 重跑差异 / blocked 归因（评审第3、5、6、7条）" vertex="1">
          <mxGeometry height="30" width="1700" x="40" y="20" as="geometry" />
        </mxCell>

        <mxCell id="p3_machineA" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=center;fontSize=13;spacingTop=10;" value="&lt;b&gt;Issue 主状态机（人）&lt;/b&gt;&#xa;&#xa;QUEUED → AUTO_RUNNING → AWAITING_REVIEW&#xa;　　↘ BLOCKED / TIMEOUT / FAILED → CLOSED&#xa;&#xa;只含人需要看到 / 处理的状态&#xa;（第1页）" vertex="1">
          <mxGeometry height="200" width="420" x="120" y="120" as="geometry" />
        </mxCell>

        <mxCell id="p3_machineB" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecf6ea;strokeColor=#82b366;verticalAlign=top;align=center;fontSize=13;spacingTop=10;" value="&lt;b&gt;调度器 / 执行状态机（自动）&lt;/b&gt;&#xa;&#xa;BOOTSTRAP→SELECT→PREPARE→START CHILD&#xa;→ CLAUDE RUN→…→ OUTCOME → AWAIT/RECORD&#xa;&#xa;doing 内部自动步骤，不需人介入&#xa;（第2页）" vertex="1">
          <mxGeometry height="200" width="460" x="980" y="120" as="geometry" />
        </mxCell>

        <mxCell id="p3_iface" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" value="唯一接口&#xa;GitLab 实时标签&#xa;(source of truth)" vertex="1">
          <mxGeometry height="90" width="180" x="620" y="175" as="geometry" />
        </mxCell>

        <mxCell id="p3_e_ab" edge="1" parent="1" source="p3_machineA" target="p3_machineB" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.3;entryX=0;entryY=0.3;fontSize=11;labelBackgroundColor=#ffffff;strokeColor=#9673a6;" value="A→B 标签事件 = 调度输入&#xa;todo / new / retry / continue / close&#xa;（tick 读到标签 → 启动子流程）">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="p3_e_ba" edge="1" parent="1" source="p3_machineB" target="p3_machineA" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0.75;entryX=1;entryY=0.75;fontSize=11;labelBackgroundColor=#ffffff;strokeColor=#82b366;" value="B→A 执行结果 = 标签写回&#xa;done+pr / blocked(归因) / timeout / failed&#xa;（outcome 写回 → 推动主状态机迁移）">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="p3_t1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;" value="&lt;b&gt;① 标签模型：label 要不要独立？（第3条）&lt;/b&gt;&#xa;&#xa;结论：拆成两个正交维度。&#xa;&#xa;&lt;b&gt;维度① 生命周期状态（互斥，任意时刻恰好一个）&lt;/b&gt;&#xa;　入口: todo / new / retry / continue&#xa;　进行: doing&#xa;　产出: done&#xa;　异常: blocked / timeout / failed&#xa;&#xa;&lt;b&gt;维度② PR 标志（独立附加，仅在 done 上有意义）&lt;/b&gt;&#xa;　pr —— 表示「MR 已存在」，叠加在 done 之上&#xa;&#xa;&lt;b&gt;互斥规则（set_issue_label.sh）&lt;/b&gt;&#xa;　加任一工作标签都会移除其它工作标签；&#xa;　仅允许两个并存对: {done+pr}、{done+blocked}(失败窗口瞬态)。&#xa;　→ 所以 pr 是独立标志；其余生命周期标签互斥。" vertex="1">
          <mxGeometry height="370" width="640" x="120" y="400" as="geometry" />
        </mxCell>

        <mxCell id="p3_t2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;" value="&lt;b&gt;② retry vs continue 的结果差异（第5条）&lt;/b&gt;&#xa;&#xa;&lt;b&gt;　　　　　　retry / fresh　　│　continue / resume&lt;/b&gt;&#xa;worktree 基线  origin/DEV_BRANCH │ origin/WORK_BRANCH&#xa;上轮产物　　　 归档不带入　　　　│ 恢复 ifp-result/issue-iid&#xa;prompt　　　　 全新　　　　　　　│ 注入上轮 summary+评审意见&#xa;触发标签　　　 retry/todo/new　　│ continue(且为唯一工作标签)&#xa;MR　　　　　　 轮换出新 MR　　　 │ 轮换出新 MR(Supersedes 旧)&#xa;pr　　　　　　 进 doing 即清除　　│ 进 doing 即清除&#xa;适用　　　　　 上轮跑偏/改了规格　│ 上轮方向对、续做&#xa;&#xa;&lt;b&gt;重跑后 pr 是否删？（第4条）&lt;/b&gt;&#xa;　删。进入 doing 的那一步 set_issue_label.sh 会移除&#xa;　{todo,new,retry,continue,done,pr,blocked,timeout,failed}，&#xa;　只留 doing；若再次达成 done，会轮换出新 MR 并重新加 pr。" vertex="1">
          <mxGeometry height="370" width="700" x="820" y="400" as="geometry" />
        </mxCell>

        <mxCell id="p3_t3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;" value="&lt;b&gt;③ blocked 归因：调度器问题 vs CC 问题（第7条）&lt;/b&gt;&#xa;&#xa;&lt;b&gt;CC 侧（Claude Code 工作问题）&lt;/b&gt;&#xa;　来源: acpx 非超时失败 / NO_CHANGES / push 被拒 / acpx 后步骤失败&#xa;　现场: 有 partial work 在 WORK_BRANCH&#xa;　人工: 读 partial+summary → continue 带说明，或 retry 重做&#xa;&#xa;&lt;b&gt;调度器侧（编排 / 基础设施问题）&lt;/b&gt;&#xa;　来源: prep 失败 / spawn 3 次失败 / scope eviction / 子流程未产出即报错&#xa;　现场: 无 CC 产出，看 block_reason&#xa;　人工: 多为环境/runner 问题 → 修复后 retry（scope eviction 不消耗 retry_count）&#xa;&#xa;两者 GitLab 标签都是 blocked；靠 block_reason / summary 区分，用户据此选 continue / retry / 修环境。" vertex="1">
          <mxGeometry height="290" width="1000" x="120" y="820" as="geometry" />
        </mxCell>

        <mxCell id="p3_t4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontSize=11;" value="&lt;b&gt;④ 人工行为 ⇄ 自动状态 的融合（第1条）&lt;/b&gt;&#xa;&#xa;人修改后在自动状态下该 continue 还是 retry，由「人打的标签」决定，&#xa;dispatcher 用 _attempt_mode_for_entry 解释：&#xa;&#xa;• 加 continue（且 continue 是唯一工作标签）→ continue 模式：&#xa;　在 origin/WORK_BRANCH 上续跑，恢复上轮产物 + 注入上轮 summary/评审意见。&#xa;• 加 retry / todo / new（或 continue 与其它工作标签并存）→ fresh 模式：&#xa;　重置到 origin/DEV_BRANCH 干净基线，归档上轮产物。&#xa;&#xa;经验法则:&#xa;• 上轮方向对、只差细节 / 只在 issue 留补充说明 → continue&#xa;• 上轮跑偏，或改了规格 / 共享配置 / 要从头来 → retry&#xa;&#xa;注意: 人改的是「标签 + issue 评论」，agent 永不自己打 continue；&#xa;continue 永远是人工评审动作。" vertex="1">
          <mxGeometry height="290" width="1000" x="1160" y="820" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
