        <mxCell id="m_e17" edge="1" parent="1" source="m_FAILED" target="m_CLOSED" style="endArrow=classic;html=1;rounded=0;fontSize=10;dashed=1;strokeColor=#bbbbbb;exitX=0.7;exitY=0;entryX=0.5;entryY=1;labelBackgroundColor=#ffffff;" value="人工关闭">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1530" y="430" />
              <mxPoint x="1680" y="430" />
            </Array>
