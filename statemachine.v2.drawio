        <mxCell id="m_e14" edge="1" parent="1" source="m_FAILED" target="m_QUEUED" style="endArrow=classic;html=1;rounded=0;fontSize=10;dashed=1;strokeColor=#9673a6;exitX=0.15;exitY=0;entryX=0.55;entryY=1;labelBackgroundColor=#ffffff;" value="人工加 retry/continue / 重新武装">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1365" y="465" />
              <mxPoint x="335" y="465" />
