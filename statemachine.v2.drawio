        <mxCell id="p2_record" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;verticalAlign=top;fontSize=11;" value="&lt;b&gt;RECORD OUTCOME&lt;/b&gt;&#xa;&#xa;record_attempt_outcome&#xa;persist attempt number + retry counters&#xa;sync label on promotion&#xa;return CampaignSummary" vertex="1">
          <mxGeometry height="210" width="330" x="2300" y="1430" as="geometry" />
