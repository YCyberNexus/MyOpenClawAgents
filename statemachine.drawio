        <mxCell id="PREPARING" parent="DOING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;PREPARING&lt;/b&gt; (dispatcher)&#xa;entry/ allocate_attempt.sh&#xa;entry/ bind k-th UI account&#xa;do/ prepare_attempt.sh&#xa;do/ build_prompt.sh&#xa;do/ set_issue_label.sh → doing&#xa;exit/ write pending_subagents[iid]" vertex="1">
          <mxGeometry height="180" width="300" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="SPAWNING" parent="DOING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;SPAWNING&lt;/b&gt; (dispatcher)&#xa;entry/ sessions_spawn (anonymous,&#xa;       timeoutSeconds=30)&#xa;do/ wait launch ack&#xa;     (runId + childSessionKey)&#xa;exit/ record ack into&#xa;       pending_subagents[iid]" vertex="1">
          <mxGeometry height="180" width="300" x="470" y="50" as="geometry" />
        </mxCell>
        <mxCell id="EXECUTING" parent="DOING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;EXECUTING&lt;/b&gt; (subagent)&#xa;entry/ Steps 0–4 (no SKILL, no state writes)&#xa;do/ run_acpx_attempt.sh&#xa;     (acpx claude exec)&#xa;do/ Claude Code generates spec&#xa;     in WORKTREE_DIR&#xa;exit/ stage_and_guard + commit_and_push&#xa;       (Strategy A force-push)" vertex="1">
          <mxGeometry height="180" width="320" x="920" y="50" as="geometry" />
        </mxCell>
        <mxCell id="PUBLISHING" parent="DOING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;PUBLISHING&lt;/b&gt; (subagent)&#xa;entry/ post_push_verify.sh&#xa;do/ upload_attempt_artifacts.sh (wiki)&#xa;do/ create_mr.sh (rotate)&#xa;do/ set_issue_label.sh add pr&#xa;do/ summarize_attempt.sh&#xa;exit/ emit ONE compact JSON line" vertex="1">
          <mxGeometry height="180" width="300" x="1390" y="50" as="geometry" />
        </mxCell>
