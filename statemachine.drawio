<mxfile host="Electron" agent="claude">
  <diagram name="主状态机-issue-lifecycle" id="issue-lifecycle">
    <mxGraphModel dx="3577" dy="1137" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="p1_title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="Issue 主状态机（GitLab label lifecycle）" vertex="1">
          <mxGeometry height="30" width="700" x="40" y="20" as="geometry" />
        </mxCell>

        <mxCell id="p1_start" parent="1" style="ellipse;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="20" width="20" x="255" y="60" as="geometry" />
        </mxCell>

        <mxCell id="p1_discard" parent="1" style="ellipse;fillColor=#FFFFFF;strokeColor=#999999;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="20" width="20" x="30" y="170" as="geometry" />
        </mxCell>
        <mxCell id="p1_discard_inner" parent="1" style="ellipse;fillColor=#999999;strokeColor=#999999;" value="" vertex="1">
          <mxGeometry height="12" width="12" x="34" y="174" as="geometry" />
        </mxCell>

        <mxCell id="p1_DRAFTING" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontSize=11;" value="&lt;b&gt;DRAFTING&lt;/b&gt; (human)&#xa;&#xa;entry/ blank issue form (no iid)&#xa;do/ user fills title &amp;amp; body locally&#xa;do/ may attach files / preview markdown&#xa;exit/ POST issue → iid assigned" vertex="1">
          <mxGeometry height="160" width="260" x="140" y="100" as="geometry" />
        </mxCell>

        <mxCell id="p1_SUBMITTED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;SUBMITTED&lt;/b&gt; (human)&#xa;&#xa;entry/ issue open on GitLab with iid&#xa;entry/ no workflow label yet&#xa;do/ PATCH body, POST notes, discuss&#xa;exit/ workflow label or reopen signal enters PENDING" vertex="1">
          <mxGeometry height="160" width="290" x="480" y="100" as="geometry" />
        </mxCell>

        <mxCell id="p1_PENDING" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=11;" value="&lt;b&gt;PENDING&lt;/b&gt; (Temporal Schedule tick)&#xa;&#xa;entry/ label ∈ {todo, new, retry, continue}&#xa;       OR reopened / open candidate&#xa;do/ ensure labels + clone_or_pull&#xa;     + reconcile GitLab&#xa;do/ retain workflow state from live labels&#xa;exit/ select eligible batch item" vertex="1">
          <mxGeometry height="180" width="330" x="850" y="100" as="geometry" />
        </mxCell>

        <mxCell id="p1_DOING" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;DOING&lt;/b&gt; (label = doing)&#xa;&#xa;entry/ acquire UI account slot, allocate attempt&#xa;entry/ prepare per-issue worktree + build executor prompt&#xa;do/ start IssueAttemptWorkflow child and await result&#xa;exit/ record outcome, drain pending, release UI slot&#xa;&#xa;&lt;i&gt;Internal flow is split into the second diagram.&lt;/i&gt;" vertex="1">
          <mxGeometry height="200" width="360" x="1260" y="100" as="geometry" />
        </mxCell>

        <mxCell id="p1_DONE" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=11;" value="&lt;b&gt;DONE&lt;/b&gt;&#xa;&#xa;entry/ labels = {done, pr}, doing removed&#xa;entry/ MR open against integration branch&#xa;do/ wait for human reviewer / merge" vertex="1">
          <mxGeometry height="160" width="280" x="1720" y="100" as="geometry" />
        </mxCell>

        <mxCell id="p1_BLOCKED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;BLOCKED&lt;/b&gt;&#xa;&#xa;entry/ remove doing, add blocked&#xa;entry/ retry_count++ (except scope eviction)&#xa;do/ cooldown before retry eligibility" vertex="1">
          <mxGeometry height="180" width="270" x="700" y="620" as="geometry" />
        </mxCell>

        <mxCell id="p1_TIMEOUT" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontSize=11;" value="&lt;b&gt;TIMEOUT&lt;/b&gt;&#xa;&#xa;entry/ remove doing, add timeout&#xa;entry/ partial work may be force-pushed&#xa;do/ no Wiki, no MR, no pr&#xa;do/ parked until reviewer strips timeout,&#xa;     adds retry, or applies continue" vertex="1">
          <mxGeometry height="210" width="300" x="1050" y="600" as="geometry" />
        </mxCell>

        <mxCell id="p1_FAILED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontSize=11;" value="&lt;b&gt;FAILED&lt;/b&gt;&#xa;&#xa;entry/ remove doing, add failed&#xa;entry/ retry budget exhausted or terminal failure&#xa;do/ never auto-reschedule" vertex="1">
          <mxGeometry height="180" width="270" x="1430" y="620" as="geometry" />
        </mxCell>

        <mxCell id="p1_CLOSED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1e1e1;strokeColor=#666666;verticalAlign=top;fontSize=11;" value="&lt;b&gt;CLOSED&lt;/b&gt;&#xa;&#xa;entry/ is_closed_on_gitlab = true&#xa;do/ hard terminal skip in reconcile&#xa;do/ never scheduled again" vertex="1">
          <mxGeometry height="180" width="270" x="1770" y="620" as="geometry" />
        </mxCell>

        <mxCell id="p1_end" parent="1" style="ellipse;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="22" width="22" x="1894" y="880" as="geometry" />
