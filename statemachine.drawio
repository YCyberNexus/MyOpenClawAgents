        <mxCell id="DOING" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=left;spacingLeft=12;startSize=24;" value="&lt;b&gt;DOING&lt;/b&gt;" vertex="1">
          <mxGeometry height="280" width="1700" x="100" y="620" as="geometry" />
