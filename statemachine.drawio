        <mxCell id="p1_legend" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=11;" value="&lt;b&gt;图例&lt;/b&gt;&#xa;━━ 正常生命周期转移&#xa;┄┄ 灰色虚线 = 草稿丢弃&#xa;&#xa;&lt;b&gt;本页范围&lt;/b&gt;&#xa;只展示 GitLab issue 主生命周期；DOING 内部执行状态已拆到第二页（Agent 内部状态机）。&#xa;&#xa;&lt;b&gt;走线规则&lt;/b&gt;&#xa;顶部一行为主路径：回流使用中部线槽；关闭路径使用右侧与底部线槽。&#xa;&#xa;&lt;b&gt;Temporal 语义&lt;/b&gt;&#xa;Schedule tick 先 bootstrap + reconcile；GitLab 实时标签是 source of truth。&#xa;CampaignWorkflow 一批启动后会 await 全部 child；无 mid-batch top-up。&#xa;&#xa;&lt;b&gt;关键状态&lt;/b&gt;&#xa;TIMEOUT 是独立停泊状态：无 MR/pr，不自动重试。&#xa;BLOCKED 消耗重试预算，超过 blocked_retry_limit 后提升为 FAILED。" vertex="1">
          <mxGeometry height="360" width="560" x="60" y="880" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="内部状态机-temporal" id="internal-execution">
    <mxGraphModel dx="3577" dy="1137" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3600" pageHeight="1750" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="p2_title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="Agent 内部状态机（CampaignWorkflow + IssueAttemptWorkflow）" vertex="1">
          <mxGeometry height="30" width="900" x="20" y="6" as="geometry" />
        </mxCell>

        <mxCell id="p2_band1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eaf2fd;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#4a6fa5;" value="CampaignWorkflow / dispatcher preparation" vertex="1">
          <mxGeometry height="300" width="1760" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_band2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ecf6ea;strokeColor=#82b366;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#5a8a4a;" value="IssueAttemptWorkflow child / technical execution" vertex="1">
          <mxGeometry height="820" width="3540" x="20" y="390" as="geometry" />
        </mxCell>
        <mxCell id="p2_band3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=13;fontStyle=1;fontColor=#666666;" value="CampaignWorkflow outcome bookkeeping" vertex="1">
          <mxGeometry height="430" width="3540" x="20" y="1250" as="geometry" />
        </mxCell>

        <mxCell id="p2_bootstrap" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;BOOTSTRAP + RECONCILE&lt;/b&gt;&#xa;&#xa;ensure_workflow_labels&#xa;self_heal_safety_bin&#xa;clone_or_pull_repo&#xa;reconcile_gitlab + classify" vertex="1">
          <mxGeometry height="180" width="300" x="70" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p2_select" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;SELECT BATCH&lt;/b&gt;&#xa;&#xa;continue → reopened → fresh → blocked cooldown&#xa;cap by max_concurrent_subagents&#xa;     + hourly_issue_quota&#xa;respect whitelist + require_labels" vertex="1">
          <mxGeometry height="180" width="330" x="470" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p2_prepare" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;PREPARE IID&lt;/b&gt;&#xa;&#xa;load UI pool + acquire slot&#xa;allocate_attempt_number&#xa;prepare_attempt_worktree&#xa;mark_issue_doing&#xa;build_executor_prompt&#xa;(secrets dereferenced worker-side)" vertex="1">
          <mxGeometry height="180" width="300" x="900" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p2_startchild" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;START CHILD&lt;/b&gt;&#xa;&#xa;IssueAttemptWorkflow.run&#xa;id = issue:{project}:{iid}:att-NNN&#xa;WorkflowIDReusePolicy.REJECT_DUPLICATE&#xa;ParentClosePolicy.ABANDON&#xa;add iid to pending" vertex="1">
          <mxGeometry height="180" width="320" x="1300" y="120" as="geometry" />
        </mxCell>

        <mxCell id="p2_e_bs_sel" edge="1" parent="1" source="p2_bootstrap" target="p2_select" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#eaf2fd;" value="reconcile evidence">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2_e_sel_prep" edge="1" parent="1" source="p2_select" target="p2_prepare" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#eaf2fd;" value="eligible IID">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2_e_prep_sc" edge="1" parent="1" source="p2_prepare" target="p2_startchild" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#eaf2fd;" value="prepared">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

