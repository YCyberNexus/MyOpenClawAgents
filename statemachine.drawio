          <mxGeometry height="140" width="240" x="790" y="400" as="geometry" />
        </mxCell>
        <mxCell id="Queued" parent="PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;verticalAlign=top;" value="&lt;b&gt;Queued&lt;/b&gt;&#xa;entry/ label ∈ {todo,new,continue,retry}&#xa;do/ wait for next scheduler tick" vertex="1">
