<mxfile host="app.diagrams.net" modified="2026-05-21T00:00:00.000Z" agent="claude" version="24.0.0" type="device">
  <diagram name="issue-lifecycle" id="issue-lifecycle">
    <mxGraphModel dx="2400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ================== 起始/终止 ================== -->
        <mxCell id="start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="900" y="40" width="20" height="20" as="geometry" />
        </mxCell>

        <mxCell id="end_terminal" value="" style="ellipse;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1030" y="1360" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="end_terminal_inner" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="1034" y="1364" width="12" height="12" as="geometry" />
        </mxCell>

        <!-- ================== 顶层状态 ================== -->
        <mxCell id="ISSUE_WRITING" value="&lt;b&gt;ISSUE_WRITING&lt;/b&gt;&#10;&#10;entry/ issue created on GitLab, iid assigned&#10;do/ write title &amp;amp; body&#10;do/ PATCH body, POST notes, discuss&#10;exit/ content ready before processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="810" y="100" width="220" height="130" as="geometry" />
        </mxCell>

        <!-- PENDING 复合状态 -->
        <mxCell id="PENDING" value="&lt;b&gt;PENDING&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=left;spacingLeft=12;startSize=24;" vertex="1" parent="1">
          <mxGeometry x="790" y="400" width="240" height="140" as="geometry" />
        </mxCell>
        <mxCell id="Queued" value="&lt;b&gt;Queued&lt;/b&gt;&#10;entry/ label ∈ {todo,new,continue,retry}&#10;do/ wait for next scheduler tick" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;verticalAlign=top;" vertex="1" parent="PENDING">
          <mxGeometry x="20" y="40" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- DOING 复合状态 -->
        <mxCell id="DOING" value="&lt;b&gt;DOING&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=left;spacingLeft=12;startSize=24;" vertex="1" parent="1">
          <mxGeometry x="100" y="620" width="1700" height="280" as="geometry" />
        </mxCell>

        <mxCell id="PREPARING" value="&lt;b&gt;PREPARING&lt;/b&gt; (dispatcher)&#10;entry/ allocate_attempt.sh&#10;entry/ bind k-th UI account&#10;do/ prepare_attempt.sh&#10;do/ build_prompt.sh&#10;do/ set_issue_label.sh → doing&#10;exit/ write pending_subagents[iid]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" vertex="1" parent="DOING">
          <mxGeometry x="20" y="50" width="300" height="180" as="geometry" />
        </mxCell>

        <mxCell id="SPAWNING" value="&lt;b&gt;SPAWNING&lt;/b&gt; (dispatcher)&#10;entry/ sessions_spawn (anonymous,&#10;       timeoutSeconds=30)&#10;do/ wait launch ack&#10;     (runId + childSessionKey)&#10;exit/ record ack into&#10;       pending_subagents[iid]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" vertex="1" parent="DOING">
          <mxGeometry x="470" y="50" width="300" height="180" as="geometry" />
        </mxCell>

        <mxCell id="EXECUTING" value="&lt;b&gt;EXECUTING&lt;/b&gt; (subagent)&#10;entry/ Steps 0–4 (no SKILL, no state writes)&#10;do/ run_acpx_attempt.sh&#10;     (acpx claude exec)&#10;do/ Claude Code generates spec&#10;     in WORKTREE_DIR&#10;exit/ stage_and_guard + commit_and_push&#10;       (Strategy A force-push)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" vertex="1" parent="DOING">
          <mxGeometry x="920" y="50" width="320" height="180" as="geometry" />
        </mxCell>

        <mxCell id="PUBLISHING" value="&lt;b&gt;PUBLISHING&lt;/b&gt; (subagent)&#10;entry/ post_push_verify.sh&#10;do/ upload_attempt_artifacts.sh (wiki)&#10;do/ create_mr.sh (rotate)&#10;do/ set_issue_label.sh add pr&#10;do/ summarize_attempt.sh&#10;exit/ emit ONE compact JSON line" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" vertex="1" parent="DOING">
          <mxGeometry x="1390" y="50" width="300" height="180" as="geometry" />
        </mxCell>

        <!-- 终态状态 -->
        <mxCell id="DONE" value="&lt;b&gt;DONE&lt;/b&gt;&#10;entry/ labels = {done, pr}, MR open&#10;do/ wait for human reviewer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1060" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="BLOCKED" value="&lt;b&gt;BLOCKED&lt;/b&gt;&#10;entry/ label = blocked, retry_count++&#10;do/ retain LOG_DIR for triage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="420" y="1060" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="FAILED" value="&lt;b&gt;FAILED&lt;/b&gt;&#10;entry/ label = failed&#10;do/ retain artifacts, never reschedule" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="930" y="1060" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="CLOSED" value="&lt;b&gt;CLOSED&lt;/b&gt;&#10;entry/ is_closed_on_gitlab = true&#10;do/ hard terminal skip in reconcile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1e1e1;strokeColor=#666666;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="930" y="1240" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- ================== 边 ================== -->

        <!-- start → ISSUE_WRITING  (issue 创建是状态机开始) -->
        <mxCell id="e1" value="create_issue / POST issue, iid assigned" style="endArrow=classic;html=1;rounded=0;fontSize=10;" edge="1" parent="1" source="start" target="ISSUE_WRITING">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ISSUE_WRITING self-loop -->
        <mxCell id="e4" value="edit/write issue&#10;/ PATCH or POST note" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.25;entryX=1;entryY=0.75;fontSize=10;curved=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ISSUE_WRITING" target="ISSUE_WRITING">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1130" y="130" />
              <mxPoint x="1130" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ISSUE_WRITING → PENDING -->
        <mxCell id="e5" value="issue_written + workflow label&#10;/ start processing" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ISSUE_WRITING" target="PENDING">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ISSUE_WRITING → CLOSED  (右侧绕一长弧) -->
        <mxCell id="e6" value="user_closes" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.95;entryX=1;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ISSUE_WRITING" target="CLOSED">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1860" y="225" />
              <mxPoint x="1860" y="1285" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- PENDING self-loop -->
        <mxCell id="e7" value="tick[!can_dispatch]&#10;/ reconcile no-op" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0.25;entryX=0;entryY=0.75;fontSize=10;curved=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="PENDING" target="PENDING">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="730" y="435" />
              <mxPoint x="730" y="505" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- PENDING → DOING -->
        <mxCell id="e8" value="tick[can_dispatch] / reconcile + prep + spawn" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="PENDING" target="DOING">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PENDING → CLOSED  (右侧弧) -->
        <mxCell id="e9" value="user_closes" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=1;entryY=0.25;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="PENDING" target="CLOSED">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1840" y="470" />
              <mxPoint x="1840" y="1263" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- DOING 内部：PREPARING → SPAWNING -->
        <mxCell id="e10" value="prep_ok" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="DOING" source="PREPARING" target="SPAWNING">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SPAWNING → EXECUTING -->
        <mxCell id="e11" value="launch_ack_ok" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="DOING" source="SPAWNING" target="EXECUTING">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- EXECUTING → PUBLISHING -->
        <mxCell id="e12" value="acpx_ok &amp;&amp; push_ok" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="DOING" source="EXECUTING" target="PUBLISHING">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SPAWNING self-loop -->
        <mxCell id="e13" value="launch_err[attempts &lt; 3]&#10;/ wait 2s, retry" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=0;entryX=0.5;entryY=0;fontSize=10;curved=1;labelBackgroundColor=#ffffff;" edge="1" parent="DOING" source="SPAWNING" target="SPAWNING">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="520" y="20" />
              <mxPoint x="720" y="20" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- DOING self-loop (外面) -->
        <mxCell id="e14" value="tick[iid_active] / reconcile, no-op" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0.25;entryX=0;entryY=0.75;fontSize=10;curved=1;" edge="1" parent="1" source="DOING" target="DOING">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="50" y="690" />
              <mxPoint x="50" y="830" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- DOING → DONE -->
        <mxCell id="e15" value="callback[done] / labels(done,pr), drain pending, kill child" style="endArrow=classic;html=1;rounded=0;exitX=0.85;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="DOING" target="DONE">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- DOING → BLOCKED  (callback) -->
        <mxCell id="e16" value="callback[blocked] / label(blocked), retry++, drain, kill" style="endArrow=classic;html=1;rounded=0;exitX=0.25;exitY=1;entryX=0.4;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="DOING" target="BLOCKED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- DOING → BLOCKED  (stuck eviction) -->
        <mxCell id="e17" value="tick[stuck] / evict, synth blocked" style="endArrow=classic;html=1;rounded=0;exitX=0.32;exitY=1;entryX=0.6;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="DOING" target="BLOCKED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- DOING → FAILED -->
        <mxCell id="e18" value="callback[failed] / label(failed), drain, kill" style="endArrow=classic;html=1;rounded=0;exitX=0.55;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="DOING" target="FAILED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- DONE → PENDING  (continue 回流，走左侧) -->
        <mxCell id="e19" value="add_label[continue] / re-enqueue, mode=continue" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.15;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="DONE" target="PENDING">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1550" y="1210" />
              <mxPoint x="60" y="1210" />
              <mxPoint x="60" y="360" />
              <mxPoint x="826" y="360" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- DONE → CLOSED  (人工合并 MR) -->
        <mxCell id="e20" value="human_merges_MR / GitLab auto-close (Closes #iid)" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.85;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="DONE" target="CLOSED">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1550" y="1170" />
              <mxPoint x="1117" y="1170" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- BLOCKED → PENDING  (retry / continue 回流，走左侧第二条) -->
        <mxCell id="e21" value="add_label[retry|continue]" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0.3;entryX=0;entryY=0.95;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="BLOCKED" target="PENDING">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="60" y="1105" />
              <mxPoint x="60" y="570" />
              <mxPoint x="790" y="570" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- BLOCKED → FAILED  (重试次数超限) -->
        <mxCell id="e22" value="tick[retry_count &gt; limit] / promote" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="1" source="BLOCKED" target="FAILED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- BLOCKED → CLOSED -->
        <mxCell id="e23" value="user_closes" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;" edge="1" parent="1" source="BLOCKED" target="CLOSED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- FAILED → CLOSED -->
        <mxCell id="e24" value="user_closes" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;" edge="1" parent="1" source="FAILED" target="CLOSED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CLOSED → end_terminal -->
        <mxCell id="e25" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="CLOSED" target="end_terminal">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================== Subagent 失败的合成 blocked（从 DOING 内三个失败点指向外部 BLOCKED 的虚线）================== -->

        <!-- PREPARING fail -->
        <mxCell id="ef1" value="prep_failed / synth blocked" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.5;exitY=1;entryX=0.05;entryY=0;fontSize=10;strokeColor=#B85450;" edge="1" parent="1" source="PREPARING" target="BLOCKED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SPAWNING fail (3 attempts) -->
        <mxCell id="ef2" value="launch_err[==3] / synth blocked" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.5;exitY=1;entryX=0.2;entryY=0;fontSize=10;strokeColor=#B85450;" edge="1" parent="1" source="SPAWNING" target="BLOCKED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- EXECUTING fail -->
        <mxCell id="ef3" value="acpx_fail || push_rejected / FAIL blocked" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.5;exitY=1;entryX=0.7;entryY=0;fontSize=10;strokeColor=#B85450;" edge="1" parent="1" source="EXECUTING" target="BLOCKED">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PUBLISHING terminal emit → DONE 走的是 callback[done]（图里已经用 DOING→DONE 抽象表达），这里不再重复 -->

        <!-- ================== 图例 ================== -->
        <mxCell id="legend" value="&lt;b&gt;图例&lt;/b&gt;&#10;━━ 正常转移&#10;┄┄ subagent 内部失败 → 合成 blocked 回调&#10;复合状态：PENDING(紫) / DOING(黄)&#10;终态色：DONE(绿) / BLOCKED(黄) / FAILED(红) / CLOSED(灰)&#10;&#10;tick = scheduler_tick（每次先跑 reconcile.sh 写证据文件）&#10;can_dispatch = reconcile_ok ∧ pending_subagents 空 ∧ batch_slot_free&#10;               ∧ launch_quota_ok ∧ ¬iid_active&#10;stuck = pending_subagents[iid] 等待 &gt; stuck_after_minutes (默认 330)&#10;source of truth = GitLab 实时标签；磁盘只是 dispatcher 进度缓存" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="440" height="200" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
