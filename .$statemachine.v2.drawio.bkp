          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_blocked_closed" edge="1" parent="1" source="BLOCKED" target="CLOSED" style="endArrow=classic;html=1;rounded=0;exitX=0.85;exitY=1;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;" value="user_closes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_failed_closed" edge="1" parent="1" source="FAILED" target="CLOSED" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;labelBackgroundColor=#ffffff;" value="user_closes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_closed_end" edge="1" parent="1" source="CLOSED" target="end_terminal" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" value="">
          <mxGeometry relative="1" as="geometry" />
