        </mxCell>

        <mxCell id="DRAFTING" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontSize=11;" value="&lt;b&gt;DRAFTING&lt;/b&gt; (human)&#xa;&#xa;entry/ blank issue form (no iid)&#xa;do/ user fills title &amp;amp; body locally&#xa;do/ may attach files / preview markdown&#xa;exit/ POST issue → iid assigned" vertex="1">
          <mxGeometry height="170" width="240" x="260" y="80" as="geometry" />
        </mxCell>

        <mxCell id="draft_discarded" parent="1" style="ellipse;fillColor=#FFFFFF;strokeColor=#666666;strokeWidth=2;" value="" vertex="1">
          <mxGeometry height="20" width="20" x="120" y="155" as="geometry" />
        </mxCell>
        <mxCell id="draft_discarded_inner" parent="1" style="ellipse;fillColor=#666666;strokeColor=#666666;" value="" vertex="1">
          <mxGeometry height="12" width="12" x="124" y="159" as="geometry" />
        </mxCell>

        <mxCell id="SUBMITTED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" value="&lt;b&gt;SUBMITTED&lt;/b&gt; (human)&#xa;&#xa;entry/ issue open on GitLab with iid&#xa;entry/ no workflow label yet&#xa;do/ PATCH body, POST notes, discuss&#xa;exit/ workflow label added → enter PENDING" vertex="1">
          <mxGeometry height="170" width="280" x="820" y="80" as="geometry" />
        </mxCell>

        <mxCell id="PENDING" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=left;spacingLeft=12;startSize=24;" value="&lt;b&gt;PENDING&lt;/b&gt; (dispatcher polls)" vertex="1">
          <mxGeometry height="180" width="300" x="770" y="290" as="geometry" />
        </mxCell>
        <mxCell id="Queued" parent="PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;verticalAlign=top;fontSize=11;" value="&lt;b&gt;Queued&lt;/b&gt;&#xa;entry/ label ∈ {todo, new, continue, retry}&#xa;do/ wait for next scheduler tick&#xa;do/ each tick runs reconcile.sh first" vertex="1">
          <mxGeometry height="120" width="260" x="20" y="40" as="geometry" />
        </mxCell>

        <mxCell id="DOING" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;align=left;spacingLeft=12;startSize=24;" value="&lt;b&gt;DOING&lt;/b&gt;  (label = doing, in-flight batch)" vertex="1">
          <mxGeometry height="310" width="1700" x="100" y="510" as="geometry" />
        </mxCell>

        <mxCell id="DOING_dispatcher_lane" parent="DOING" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef4fb;strokeColor=none;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=10;fontColor=#6c8ebf;" value="dispatcher" vertex="1">
          <mxGeometry height="270" width="720" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="DOING_subagent_lane" parent="DOING" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef7ec;strokeColor=none;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=10;fontColor=#82b366;" value="subagent (anonymous run, per IID)" vertex="1">
          <mxGeometry height="270" width="940" x="750" y="30" as="geometry" />
        </mxCell>

        <mxCell id="doing_initial" parent="DOING" style="ellipse;fillColor=#000000;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="14" width="14" x="18" y="168" as="geometry" />
        </mxCell>

        <mxCell id="PREPARING" parent="DOING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;PREPARING&lt;/b&gt;&#xa;entry/ allocate_attempt.sh&#xa;entry/ bind k-th UI account slot&#xa;do/ prepare_attempt.sh (per-issue worktree)&#xa;do/ if mode=continue ∧ origin/${WORK_BRANCH}&#xa;     missing → downgrade to fresh&#xa;     (only documented exception)&#xa;do/ build_prompt.sh&#xa;do/ set_issue_label.sh → doing&#xa;exit/ pending_subagents[iid] placeholder" vertex="1">
          <mxGeometry height="230" width="320" x="40" y="60" as="geometry" />
        </mxCell>

        <mxCell id="SPAWNING" parent="DOING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;SPAWNING&lt;/b&gt;&#xa;entry/ sessions_spawn (anonymous,&#xa;       timeoutSeconds=30,&#xa;       runTimeoutSeconds=18120)&#xa;do/ wait launch ack&#xa;     (runId + childSessionKey)&#xa;exit/ record ack into&#xa;       pending_subagents[iid]" vertex="1">
          <mxGeometry height="230" width="320" x="390" y="60" as="geometry" />
        </mxCell>

        <mxCell id="EXECUTING" parent="DOING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;EXECUTING&lt;/b&gt;&#xa;entry/ subagent Steps 0–4&#xa;       (no SKILL, no state writes)&#xa;do/ run_acpx_attempt.sh&#xa;     (acpx claude exec, one-shot)&#xa;do/ Claude Code generates spec&#xa;     in WORKTREE_DIR&#xa;exit/ stage_and_guard.sh&#xa;       + commit_and_push.sh&#xa;       (Strategy A force-push)" vertex="1">
          <mxGeometry height="230" width="350" x="770" y="60" as="geometry" />
        </mxCell>

        <mxCell id="PUBLISHING" parent="DOING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" value="&lt;b&gt;PUBLISHING&lt;/b&gt;&#xa;entry/ post_push_verify.sh&#xa;do/ upload_attempt_artifacts.sh (Wiki)&#xa;do/ create_mr.sh (rotate)&#xa;do/ set_issue_label.sh add pr&#xa;do/ summarize_attempt.sh&#xa;exit/ emit ONE compact JSON line&#xa;       → runtime fires&#xa;       RUN_CHILD_COMPLETION_CALLBACK" vertex="1">
          <mxGeometry height="230" width="320" x="1150" y="60" as="geometry" />
        </mxCell>

        <mxCell id="e_init_prep" edge="1" parent="DOING" source="doing_initial" target="PREPARING" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_prep_spawn" edge="1" parent="DOING" source="PREPARING" target="SPAWNING" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;" value="prep_ok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_spawn_exec" edge="1" parent="DOING" source="SPAWNING" target="EXECUTING" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;" value="launch_ack_ok&#xa;/ return waiting_for_callbacks">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_exec_pub" edge="1" parent="DOING" source="EXECUTING" target="PUBLISHING" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;labelBackgroundColor=#ffffff;" value="acpx_ok &amp;&amp; push_ok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_spawn_self" edge="1" parent="DOING" source="SPAWNING" target="SPAWNING" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=0;entryX=0.5;entryY=0;fontSize=10;curved=1;labelBackgroundColor=#ffffff;" value="launch_err[attempts &lt; 3]&#xa;/ wait 2s, retry same payload">
          <mxGeometry relative="1" as="geometry">
