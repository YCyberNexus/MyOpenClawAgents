        <mxCell id="CLOSED" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1e1e1;strokeColor=#666666;verticalAlign=top;fontSize=11;" value="&lt;b&gt;CLOSED&lt;/b&gt;&#xa;entry/ is_closed_on_gitlab = true&#xa;do/ hard terminal skip in reconcile&#xa;do/ never scheduled again" vertex="1">
